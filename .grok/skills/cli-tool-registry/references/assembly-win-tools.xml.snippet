<!-- Add to Windows assembly descriptor (e.g. {{ARTIFACT_ID}}-dist-win.xml) -->
<!-- Required for Variant F2 (context-menu-launcher) -->

<fileSet>
    <directory>src/main/assembly/win-tools</directory>
    <outputDirectory>win-tools/</outputDirectory>
</fileSet>

<!-- Place singleinstance.exe in src/main/assembly/win-tools/ -->
<!-- Download: https://github.com/owenstake/context-menu-launcher/releases -->